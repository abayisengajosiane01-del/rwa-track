generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  email        String     @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  role         Role       @default(WORKER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  worker       Worker?
  managedWorkers Worker[] @relation("HRWorkers")
  auditLogs    AuditLog[]
  sessions     Session[]
}

model Worker {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  hrId            String?  @db.ObjectId
  jobTitle        String
  homeLat         Float?
  homeLng         Float?
  homeAddress     String?
  workLat         Float?
  workLng         Float?
  workAddress     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hr              User?    @relation("HRWorkers", fields: [hrId], references: [id])
  locationLogs    LocationLog[]
}

model LocationLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  workerId   String   @db.ObjectId
  lat        Float
  lng        Float
  accuracy   Float?
  recordedAt DateTime @default(now())

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  HR
  WORKER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
